# Avito OAuth credentials — получить в https://www.avito.ru/professionals/api
Client_id=
Client_secret=

# ID профиля Авито (виден на странице профиля).
# Автоматически подставляется в {user_id}/{userId} пути всех методов,
# если LLM-агент не передал явно.
Profile_id=

# Опционально: путь к файлу OAuth-токена.
# По умолчанию — per-user state directory:
#   Linux:   $XDG_STATE_HOME/avito-mcp/token.json  (≈ ~/.local/state/avito-mcp/token.json)
#   macOS:   ~/Library/Application Support/avito-mcp/token.json
#   Windows: %APPDATA%\avito-mcp\token.json
# AVITO_TOKEN_FILE=

# Опционально: режим работы. Три значения:
#   read_only   — регистрирует только tools с risk='read' (~79 tools)
#                 GET'ы и POST-as-query: статистика, аналитика, баланс, инфо.
#                 Идеально для аналитического агента или первого знакомства.
#   guarded     — регистрирует 'read' + 'write' (~120 tools), скрывает 'money' и 'public'.
#                 Агент может менять собственные данные (drafts, settings, stock),
#                 но не потратит деньги и не отправит сообщение клиенту.
#   full_access — все 139 tools (default; legacy v0.1.x поведение).
# AVITO_MCP_MODE=full_access

# Опционально: allowlist tools. Если указан — регистрируются ТОЛЬКО эти имена.
# Удобно для агента-персоны с очень узким scope. Имена через запятую (или пробел).
# AVITO_MCP_ALLOW_TOOLS=user_get_user_balance,items_get_items_info,meta_get_rate_limits

# Опционально: denylist tools. Указанные имена всегда скрыты, даже если они есть
# в allowlist или разрешены текущим mode. Deny всегда побеждает.
# AVITO_MCP_DENY_TOOLS=items_put_item_vas,promotion_create_bbip_order_for_items_v1

# Опционально (deprecated since v0.3.0): то же что AVITO_MCP_MODE=read_only.
# Оставлено для обратной совместимости с v0.2.x — лучше используйте AVITO_MCP_MODE.
# AVITO_SAFE_MODE=read-only

# Опционально: базовый URL Avito API (для тестового сервера / прокси).
# AVITO_BASE_URL=https://api.avito.ru

# Опционально: уровень логирования pino (trace|debug|info|warn|error|fatal). По умолчанию info.
# LOG_LEVEL=info
