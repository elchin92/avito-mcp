# Avito OAuth credentials — получить в https://www.avito.ru/professionals/api
Client_id=
Client_secret=

# ID профиля Авито (виден на странице профиля).
# Автоматически подставляется в {user_id}/{userId} пути всех методов,
# если LLM-агент не передал явно.
Profile_id=

# Опционально: путь к файлу OAuth-токена.
# По умолчанию — per-user state directory:
#   Linux:   $XDG_STATE_HOME/avito-mcp/token.json  (≈ ~/.local/state/avito-mcp/token.json)
#   macOS:   ~/Library/Application Support/avito-mcp/token.json
#   Windows: %APPDATA%\avito-mcp\token.json
# AVITO_TOKEN_FILE=

# ────────────────── Safety: registration-time gates ──────────────────
# Применяются ДО регистрации tool — отсеянные инструменты вообще не появляются
# в tools/list, агент их не видит.

# Режим работы. Три значения:
#   read_only   — регистрирует только tools с risk='read' (80 tools в v1.2.0).
#                 GET'ы и POST-as-query: статистика, аналитика, баланс, инфо.
#   guarded     — регистрирует 'read' + 'write' (120 tools в v1.2.0), скрывает
#                 'money' и 'public'.
#                 Агент может менять собственные данные, но не потратит деньги
#                 и не отправит сообщение клиенту.
#   full_access — все 145 обычных tools (default). Ещё 3 sensitive auth tools
#                 появляются только при AVITO_MCP_EXPOSE_AUTH_TOOLS=1.
# AVITO_MCP_MODE=full_access

# Allowlist tools: если непусто — регистрируются ТОЛЬКО эти имена.
# Удобно для агента-персоны с очень узким scope.
# AVITO_MCP_ALLOW_TOOLS=user_get_user_balance,items_get_items_info,meta_get_rate_limits

# Denylist tools: указанные имена всегда скрыты. Deny побеждает allow.
# AVITO_MCP_DENY_TOOLS=items_put_item_vas,promotion_create_bbip_order_for_items_v1

# Sensitive tools (auth_*): скрыты по DEFAULT даже в full_access, потому что
# возвращают credentials/tokens. Включайте только если строите сборку под
# конкретный flow auth-debug — и ограничивайте allowlist.
# AVITO_MCP_EXPOSE_AUTH_TOOLS=0

# Опционально (deprecated с v0.3.0): то же что AVITO_MCP_MODE=read_only.
# Оставлено для обратной совместимости с v0.2.x.
# AVITO_SAFE_MODE=read-only

# ────────────────── Safety: upload guard ──────────────────
# messenger_upload_images читает локальные файлы и отправляет их в Avito.
# Без AVITO_MCP_ALLOWED_UPLOAD_DIRS tool вообще не регистрируется (fail-closed).
# Указывайте конкретные директории, которые агенту разрешено читать.
# AVITO_MCP_ALLOWED_UPLOAD_DIRS=/Users/you/avito-uploads,/tmp/avito-safe

# Максимальный размер одного файла upload, MB. Default = 15.
# AVITO_MCP_MAX_UPLOAD_MB=15

# Проверки при upload (нельзя выключить):
# realpath (symlink escape), allowlist директорий, размер, расширение
# (jpg/jpeg/png/webp), magic-byte sniff с cross-check на extension.

# ────────────────── Safety: runtime confirmation ──────────────────
# Confirmation gate срабатывает ПОСЛЕ регистрационного фильтра, на runtime:
#   off              — без подтверждений, tools выполняются сразу (v0.3.x поведение)
#   money_public     — money и public требуют meta_confirm_action (default)
#   all_destructive  — money, public И write требуют подтверждения
#
# Сам confirmation: tool возвращает {"requires_confirmation": true, "confirmation_id": "..."},
# агент должен вызвать meta_confirm_action с этим id. Use is one-time. Pending state
# хранится только in-memory и теряется при рестарте сервера.
#
# Важно: confirmation — это server-side two-step safety guard от случайного one-shot
# выполнения и audit layer. Это НЕ криптографическая защита от автономного агента —
# тот же агент может вызвать meta_confirm_action автоматически. Сила flow раскрывается
# в MCP-клиентах, которые требуют user approval на каждый tool call.
# AVITO_MCP_CONFIRMATION_MODE=money_public

# TTL pending action в секундах. Default 900 (15 минут).
# AVITO_MCP_CONFIRMATION_TTL_SEC=900

# v0.5.0: hard-confirmation. Если задано — meta_confirm_action требует параметр
# confirmation_secret, сравниваемый constant-time с этой env-переменной. Значение
# должно быть случайным и иметь длину минимум 32 символа. Без совпадения
# подтверждение отклоняется. После 5 неправильных попыток pending action удаляется.
#
# Эта переменная переводит confirmation flow из soft-confirmation (агент сам
# может вызвать meta_confirm_action) в hard-confirmation (агент должен получить
# секрет из внешнего канала, чаще всего ввод человека в чате клиента).
# Сильнее всего работает в паре с MCP-клиентом, который показывает confirmation_id
# человеку и просит ввести секрет вручную.
# Example: openssl rand -base64 32
# AVITO_MCP_CONFIRMATION_SECRET=

# Лимит размера ЛЮБОГО HTTP-ответа в MB (JSON/text/PDF/audio).
# Если сервер заявит Content-Length больше — отказ до чтения. Если без header — отказ
# после чтения по фактическому размеру. Default 20 MB.
# AVITO_MCP_MAX_BINARY_MB=20

# ────────────────── v0.7.0: universal hardening (opt-in) ──────────────────

# Default for `dryRun` parameter on destructive tools. Когда true — каждый
# write/money/public tool возвращает preview HTTP-запроса вместо реального вызова,
# пока агент явно не передаст dryRun:false. Эквивалент CLI флага --dry-run.
# Default: false (поведение v0.6.x сохраняется).
# AVITO_MCP_DRY_RUN_DEFAULT=false

# TTL idempotency ledger в секундах. Каждый destructive tool теперь принимает
# опциональный idempotencyKey: повторный вызов с тем же ключом и теми же args в течение
# TTL возвращает закешированный результат (idempotent_replay=true). Тот же ключ с другими
# args вернёт IdempotencyConflictError. Ledger in-memory, теряется при рестарте.
# Default 3600 (1 час).
# AVITO_MCP_IDEMPOTENCY_TTL_SEC=3600

# Максимальное ожидание межпроцессного файл-lock'а при OAuth refresh, в миллисекундах.
# Защищает от thundering-herd когда несколько процессов avito-mcp (cron, CLI, MCP-клиент)
# одновременно делают refresh /token. Внутри lock — double-check файла токена.
# Default 30000 (30s).
# AVITO_MCP_TOKEN_LOCK_TIMEOUT_MS=30000

# ────────────────── v0.9.0: remote MCP over HTTP (OAuth 2.1) ──────────────────
# По умолчанию сервер говорит по stdio (локально). В http/both-режиме он отдаёт
# те же tools по сети как Streamable HTTP MCP, защищённый OAuth 2.1.
# Node ВСЕГДА слушает loopback (127.0.0.1); TLS терминирует reverse-proxy
# (nginx/Caddy) на вашем домене и проксирует на http://127.0.0.1:3000.
# Готовые сниппеты nginx/Caddy — в README (раздел "Remote MCP").

# Транспорт: stdio (default) | http | both. CLI-эквивалент: флаг --http.
#   stdio — только локально (поведение v0.8.0).
#   http  — только сетевой Streamable HTTP MCP на /mcp.
#   both  — stdio И http одновременно.
# AVITO_MCP_TRANSPORT=stdio

# Bind-адрес и порт HTTP-листенера. Держите host loopback за reverse-proxy.
# AVITO_MCP_HTTP_HOST=127.0.0.1
# AVITO_MCP_HTTP_PORT=3000

# Публичный TLS-URL, по которому виден сервер. Используется для построения
# OAuth issuer / resource metadata. БЕЗ завершающего слэша.
# AVITO_MCP_HTTP_PUBLIC_URL=https://mcp.example.com

# Режим авторизации HTTP-транспорта: oauth (default) | bearer | none.
#   oauth  — полный OAuth 2.1: клиенты сами регистрируются (DCR /register),
#            проходят authorization-code + PKCE, человек подтверждает на /authorize
#            owner-паролем, выданный bearer-токен защищает /mcp.
#   bearer — общий секрет(ы) в AVITO_MCP_HTTP_AUTH_TOKEN (через запятую).
#   none   — без авторизации. На не-loopback хосте отклоняется, пока не задано
#            AVITO_MCP_HTTP_ALLOW_NO_AUTH=1 (не рекомендуется).
# AVITO_MCP_HTTP_AUTH=oauth

# ОБЯЗАТЕЛЬНО в режиме oauth: owner-пароль, который закрывает экран /authorize.
# Единственный секрет, которым можно выпустить токен — кто его знает, тот может
# подключить клиента. Минимум 32 байта; используйте случайную строку.
# AVITO_MCP_OAUTH_OWNER_PASSWORD=

# Время жизни выпущенного bearer-токена, секунды. Default 3600 (1 час).
# AVITO_MCP_OAUTH_TOKEN_TTL_SEC=3600

# Опциональный файл для персиста выпущенных токенов/клиентов между рестартами.
# Без него всё in-memory и теряется при рестарте. Один store-файл может принадлежать
# только одному запущенному процессу avito-mcp; второй процесс fail-closed.
# AVITO_MCP_OAUTH_STORE_FILE=

# Режим bearer: общий секрет(ы) для Authorization: Bearer на /mcp. Через запятую;
# каждый токен минимум 32 байта.
# AVITO_MCP_HTTP_AUTH_TOKEN=

# Разрешить AVITO_MCP_HTTP_AUTH=none на не-loopback хосте. По умолчанию запрещено.
# AVITO_MCP_HTTP_ALLOW_NO_AUTH=0

# Защита от DNS-rebinding: CSV допустимых значений заголовков Host / Origin.
# Если не задано — allowlist выводится из public URL + адреса бинда. Если при
# wildcard-бинде нельзя вывести одновременно Host и Origin, startup fail-closed:
# задайте публичный URL или оба явных allowlist.
# AVITO_MCP_HTTP_ALLOWED_HOSTS=mcp.example.com
# AVITO_MCP_HTTP_ALLOWED_ORIGINS=https://mcp.example.com

# v1.0.0: лимиты Streamable HTTP сессий. initialize сверх MAX_SESSIONS → 503;
# сессии, простаивающие дольше SESSION_IDLE_SEC, закрываются автоматически
# (клиент исчез без DELETE — крэш, сон ноутбука, смена сети).
# AVITO_MCP_HTTP_MAX_SESSIONS=100
# AVITO_MCP_HTTP_SESSION_IDLE_SEC=1800

# ────────────────── v0.9.0: Avito webhook receiver ──────────────────
# Встроенный приёмник push-событий мессенджера Avito (новые сообщения / события чатов).
# Avito POST'ит на секретный URL, сервер буферизует события для агента.
# Работает ДАЖE в чистом stdio-режиме — Avito нужен публичный URL, MCP-клиенту нет
# (при stdio + заданном секрете сервер поднимает крошечный HTTP-listener для приёмника).
# Эндпоинт: POST {PUBLIC_URL}{PATH}/{SECRET} → 200 {"ok":true} (быстрее 2с-дедлайна Avito).
# Новые tools: messenger_get_webhook_events / messenger_get_webhook_status /
# messenger_register_webhook. Новый subscribable-resource: avito://webhook/events.

# Секрет включает приёмник и становится неугадываемым сегментом пути (это и есть auth).
# Секрет ОБЯЗАТЕЛЕН: без него приёмник не включается ничем; минимум 32 байта.
# AVITO_MCP_WEBHOOK_SECRET=

# Явный тумблер: =0 выключает приёмник, НЕ убирая секрет из конфига.
# v1.0.0: =1 без секрета ничего не включает (приёмник без секрета бесполезен) —
# сервер предупредит об этом при старте.
# AVITO_MCP_WEBHOOK_ENABLED=1

# Публичный базис, куда POST'ит Avito. По умолчанию — AVITO_MCP_HTTP_PUBLIC_URL.
# AVITO_MCP_WEBHOOK_PUBLIC_URL=https://mcp.example.com

# Префикс пути перед секретным сегментом. Default /avito/webhook.
# AVITO_MCP_WEBHOOK_PATH=/avito/webhook

# Размер in-memory ring-буфера событий. Default 100.
# AVITO_MCP_WEBHOOK_BUFFER=100

# Опциональный JSONL-файл: пишется только нормализованная metadata без текста
# сообщений/raw payload. Файл 0600, ротация при 10 MiB, хранится active + 1 backup.
# Для systemd используйте state directory, доступный service user.
# AVITO_MCP_WEBHOOK_LOG_FILE=/var/lib/avito-mcp/webhook-events.jsonl

# ────────────────── Misc ──────────────────
# Базовый URL Avito API (для тестового сервера / прокси).
# AVITO_BASE_URL=https://api.avito.ru

# Обязательный X-Source для CPA API. 1–64 символа: буквы, цифры, . _ -
# Default: avito-mcp.
# AVITO_MCP_CPA_SOURCE=avito-mcp

# Уровень логирования pino (trace|debug|info|warn|error|fatal). По умолчанию info.
# LOG_LEVEL=info

# v1.2.0: env разбирается строго. Неизвестное enum/boolean, дробное/частично
# числовое значение или число вне лимита останавливает startup с понятной ошибкой.
