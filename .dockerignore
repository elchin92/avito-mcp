.npmrc*
.avito-token.json*
.mcp.json*
!.mcp.json.example
*.pem
*.pem.*
*.key
*.key.*
*.jsonl
deploy/Caddyfile
PROJECT_AUDIT.md
AUDIT-*.md
*.tgz
logs
*.log

